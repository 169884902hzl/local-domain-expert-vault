{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Seed v2 Publish Result",
  "type": "object",
  "required": ["schema_version", "run_date", "status", "v2_publish_policy", "formal_seed_publish_allowed", "formal_seed_written", "published", "blocked"],
  "properties": {
    "schema_version": {"type": "string", "const": "publish_result.v1"},
    "run_date": {"type": "string"},
    "status": {"type": "string"},
    "v2_publish_policy": {"type": "string", "enum": ["disabled", "seed-candidates-only", "formal"]},
    "formal_seed_publish_allowed": {"type": "boolean"},
    "scheduled_daily_switched": {"type": "boolean"},
    "formal_seed_written": {"type": "boolean"},
    "test_provider_used_for_formal": {"type": "boolean"},
    "formal_publish_risk": {"type": "string"},
    "formal_rehearsal_written": {"type": "boolean"},
    "published": {"type": "array"},
    "bucketed": {"type": "array"},
    "blocked": {"type": "array"},
    "artifact_hashes": {"type": "object"}
  }
}
