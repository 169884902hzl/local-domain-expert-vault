{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Seed v2 Raw Candidates",
  "type": "object",
  "required": ["schema_version", "run_date", "candidates", "lanes"],
  "properties": {
    "schema_version": {"type": "string", "const": "raw_candidate.v1"},
    "run_date": {"type": "string"},
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "title": {"type": "string"},
          "lane": {"type": "string"}
        }
      }
    },
    "lanes": {"type": "array"},
    "artifact_hashes": {"type": "object"},
    "boundary": {"type": "string"}
  }
}
