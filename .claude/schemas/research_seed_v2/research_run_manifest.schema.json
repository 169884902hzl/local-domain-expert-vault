{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Seed v2 Manifest",
  "type": "object",
  "required": ["schema_version", "state_machine_version", "run_id", "run_date", "states", "formal_seed_written"],
  "properties": {
    "schema_version": {"type": "string", "const": "research_run_manifest.v1"},
    "state_machine_version": {"type": "string"},
    "run_id": {"type": "string"},
    "run_date": {"type": "string"},
    "states": {"type": "array"},
    "v2_publish_policy": {"type": "string", "enum": ["disabled", "seed-candidates-only", "formal"]},
    "formal_seed_publish_allowed": {"type": "boolean"},
    "scheduled_daily_switched": {"type": "boolean"},
    "formal_seed_written": {"type": "boolean"},
    "test_provider_used_for_formal": {"type": "boolean"},
    "formal_publish_risk": {"type": "string"}
  }
}
