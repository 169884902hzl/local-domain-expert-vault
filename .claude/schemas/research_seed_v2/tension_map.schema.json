{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Seed v2 Tension Map",
  "type": "object",
  "required": ["schema_version", "run_date", "tensions", "speculative_tensions"],
  "properties": {
    "schema_version": {"type": "string", "const": "tension_map.v1"},
    "run_date": {"type": "string"},
    "tension_types": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tensions": {
      "type": "array",
      "items": {"$ref": "#/$defs/tension"}
    },
    "speculative_tensions": {
      "type": "array",
      "items": {"$ref": "#/$defs/tension"}
    },
    "validation_errors": {"type": "array", "items": {"type": "string"}},
    "artifact_hashes": {"type": "object"},
    "boundary": {"type": "string"}
  },
  "$defs": {
    "tension": {
      "type": "object",
      "required": [
        "tension_id",
        "tension_type",
        "summary",
        "supporting_nodes",
        "confidence",
        "source",
        "do_not_use_as_seed_evidence"
      ],
      "properties": {
        "tension_id": {"type": "string", "minLength": 1},
        "tension_type": {
          "type": "string",
          "enum": [
            "assumption_conflict",
            "evaluation_blind_spot",
            "missing_latent_variable",
            "interface_boundary_mismatch",
            "baseline_contradiction",
            "data_distribution_pathology",
            "lab_specific_engineering_bottleneck",
            "external_analogy_opportunity",
            "negative_result_opportunity",
            "benchmark_gap",
            "speculative_tension"
          ]
        },
        "summary": {"type": "string"},
        "supporting_nodes": {"type": "array", "items": {"type": "string"}},
        "supporting_edges": {"type": "array", "items": {"type": "string"}},
        "tension_scope": {"type": "string", "enum": ["same_paper", "cross_paper", "speculative"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low", "unusable"]},
        "source": {"type": "string"},
        "do_not_use_as_seed_evidence": {"type": "boolean"},
        "requires_human_check": {"type": "boolean"},
        "edge_quality_status": {"type": "string"},
        "risk_markers": {"type": "array", "items": {"type": "string"}},
        "original_tension_type": {"type": "string"},
        "allowed_lane": {"type": "string"}
      }
    }
  }
}
