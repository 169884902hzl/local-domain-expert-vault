{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Seed v2 Novelty Scan",
  "type": "object",
  "required": ["schema_version", "run_date", "status", "scans"],
  "properties": {
    "schema_version": {"type": "string", "const": "novelty_scan.v1"},
    "run_date": {"type": "string"},
    "status": {"type": "string", "enum": ["completed", "completed_local_only", "partial_empty_selection"]},
    "scans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "novelty_classification", "promotion_allowed", "formal_promotion_allowed", "verification_scope", "external_providers_used", "nearest_works", "duplicate_guard"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "candidate_title": {"type": "string"},
          "status": {"type": "string"},
          "novelty_classification": {"type": "string", "enum": ["likely_open", "partial_overlap", "unknown", "duplicate"]},
          "novelty_remaining_delta": {"type": "string"},
          "promotion_allowed": {"type": "boolean"},
          "formal_promotion_allowed": {"type": "boolean"},
          "verification_scope": {"type": "string", "enum": ["local_only", "local_plus_arxiv_api", "local_plus_s2_or_openalex", "strict_multi_provider"]},
          "external_providers_used": {"type": "array", "items": {"type": "string"}},
          "formal_publish_risk": {"type": "string"},
          "classification_reason": {"type": "string"},
          "nearest_works": {"type": "array"},
          "local_scan_evidence": {"type": "object"},
          "external_scan_evidence": {"type": "object"},
          "duplicate_guard": {"type": "object"}
        }
      }
    },
    "provider_policy": {"type": "object"},
    "artifact_hashes": {"type": "object"}
  }
}
