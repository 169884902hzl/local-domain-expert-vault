{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Governance v1 Nearest Work Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate_id", "works", "boundary"],
  "properties": {
    "schema_version": {"const": "nearest_work_matrix.v1"},
    "candidate_id": {"type": "string", "minLength": 1},
    "works": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {"type": "string"},
          "source": {"type": "string"},
          "overlap_type": {"type": "string"},
          "remaining_delta": {"type": "string"},
          "metadata": {"type": "object"}
        }
      }
    },
    "boundary": {"type": "string"}
  }
}
