{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Governance v1 Provider Review Packet",
  "type": "object",
  "required": ["schema_version", "candidate_id", "review_status", "provider_backed", "test_provider_used", "provider_status"],
  "properties": {
    "schema_version": {"const": "provider_review_packet.v1"},
    "candidate_id": {"type": "string", "minLength": 1},
    "review_status": {"type": "string", "enum": ["success", "blocked", "timeout", "provider_unavailable", "partial_provider_unavailable"]},
    "provider_backed": {"type": "boolean"},
    "test_provider_used": {"type": "boolean"},
    "provider_status": {
      "type": "object",
      "required": ["provider_backed", "mode"],
      "properties": {
        "provider_backed": {"type": "boolean"},
        "mode": {"type": "string"},
        "status": {"type": "string"}
      }
    },
    "reviews": {"type": "array"},
    "artifact_hashes": {"type": "array"}
  }
}
